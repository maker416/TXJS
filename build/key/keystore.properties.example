# Android Release 签名配置
# 用法 1：复制本文件为 keystore.properties，填入真实密码
# 用法 2：运行 build/generate-keystore.ps1 自动生成密钥库与本文件
#
# 注意：keystore.properties 与 release.keystore 含敏感信息，请勿提交到 Git

storeFile=build/key/release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=txjs-release
keyPassword=YOUR_KEY_PASSWORD
