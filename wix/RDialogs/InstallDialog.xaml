<wixsharp:WpfDialog
    x:Class="RSetup.RDialogs.InstallDirDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wixsharp="clr-namespace:WixSharp.UI.WPF;assembly=WixSharp.UI.WPF"
    d:DesignHeight="408"
    d:DesignWidth="512"
    DialogTitle="选择原版铁锈战争游戏目录"
    mc:Ignorable="d">
    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="53" />
        </Grid.RowDefinitions>
        <Border
            Margin="-1,-1,-1,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderBrush="Gray"
            BorderThickness="1">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <Image
                    x:Name="Banner"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="1,2,2,1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Source="{Binding Banner}" />
                <StackPanel Margin="9">
                    <TextBlock
                        Grid.Column="0"
                        FontSize="12"
                        FontWeight="Bold"
                        Text="选择原版铁锈战争游戏目录" />
                    <TextBlock
                        x:Name="DialogDescription"
                        Margin="17,5"
                        VerticalAlignment="Stretch"
                        Text="RWJS 是启动器，请把它安装到原版 Rusted Warfare 根目录。示例：D:\APP\Steam\steamapps\common\Rusted Warfare"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,10">
            <TextBlock
                MinHeight="58"
                Text="请确认下面路径是原版游戏目录。安装器会检测 steam_appid、原版 exe、game-lib.jar、assets/res/libs 等特征；至少命中一个即可继续。"
                TextWrapping="Wrap" />
            <TextBox
                x:Name="InstallDirPath"
                Height="33"
                Margin="0,10"
                VerticalContentAlignment="Center"
                Text="{Binding InstallDirPath}" />
            <Button
                x:Name="ChangeInstallDir"
                Height="28"
                MinWidth="140"
                HorizontalAlignment="Left"
                Click="ChangeInstallDir_Click"
                Content="浏览..." />
        </StackPanel>

        <Border
            Grid.Row="2"
            Margin="-1,0,-1,-1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderBrush="Gray"
            BorderThickness="1">
            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Separator Width="10" Opacity="0" />
                <Button
                    x:Name="GoPrev"
                    Height="28"
                    MinWidth="73"
                    Click="GoPrev_Click">
                    [WixUIBack]
                </Button>
                <Separator Width="10" Opacity="0" />
                <Button
                    x:Name="GoNext"
                    Height="28"
                    MinWidth="73"
                    Click="GoNext_Click">
                    [WixUINext]
                </Button>
                <Separator Width="20" Opacity="0" />
                <Button
                    x:Name="Cancel"
                    Height="28"
                    MinWidth="73"
                    Click="Cancel_Click">
                    [WixUICancel]
                </Button>
                <Separator Width="10" Opacity="0" />
            </StackPanel>
        </Border>
    </Grid>
</wixsharp:WpfDialog>
